# Ignore everything at repository root
/*

# Allow GitHub workflow/config
!.gitignore
!.github/
!.github/**

# Allow wp-content folder itself, but ignore its contents by default
!wp-content/
wp-content/*

# Allow only selected theme
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/alminuto-theme/
!wp-content/themes/alminuto-theme/**

# Allow plugins folder, but ignore runtime/generated/plugin backup junk inside if needed
!wp-content/plugins/
!wp-content/plugins/**

# If you DON'T want every plugin, use this instead of the two plugin lines above:
# !wp-content/plugins/
# wp-content/plugins/*
# !wp-content/plugins/nombre-plugin-1/
# !wp-content/plugins/nombre-plugin-1/**
# !wp-content/plugins/nombre-plugin-2/
# !wp-content/plugins/nombre-plugin-2/**

# Never track WordPress generated/runtime folders
wp-content/uploads/
wp-content/cache/
wp-content/upgrade/
wp-content/updraft/
wp-content/aiowps_backups/
wp-content/upgrade-temp-backup/
wp-content/backups/
wp-content/backup*/
wp-content/wflogs/
wp-content/languages/
wp-content/mu-plugins/

# Never track generated/config files inside wp-content
wp-content/index.php
wp-content/debug.log
wp-content/sgo-config.php
wp-content/sgs_encrypt_key.php

# Never track old/default themes or theme zips
wp-content/themes/twentytwenty*/
wp-content/themes/*.zip
wp-content/themes/index.php

# WordPress config/secrets
wp-config.php
wp-config-*.php
.env
.env.*

# Backups, dumps and archives anywhere
*.sql
*.sql.gz
*.zip
*.tar
*.tar.gz
*.tgz
*.bak
*.backup

# Logs
*.log

# OS/editor files
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/

# Dependency/cache folders
node_modules/
.npm/
.pnpm-store/
.cache/
.parcel-cache/
.vite/
.turbo/

# FTP deploy state
.ftp-deploy-sync-state.json